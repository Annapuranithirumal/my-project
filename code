<!DOCTYPE html>
<html>
<head>
<title>Online Shopping</title>

<style>

body{
    font-family: Arial, sans-serif;
    background: linear-gradient(120deg,#ff9a9e,#fad0c4,#fad0c4);
    text-align:center;
    margin:0;
}

/* header */
header{
    background-color:#ff3f6c;
    color:white;
    padding:20px;
    font-size:28px;
    font-weight:bold;
}

/* product card */
.product{
    background:white;
    width:300px;
    margin:80px auto;
    padding:25px;
    border-radius:10px;
    box-shadow:0 4px 10px rgba(0,0,0,0.2);
}

.product img{
    width:100%;
    border-radius:8px;
}

.price{
    font-size:20px;
    color:#333;
    margin:10px 0;
}

/* button */
button{
    background:#ff3f6c;
    color:white;
    border:none;
    padding:12px 20px;
    font-size:16px;
    border-radius:5px;
    cursor:pointer;
}

button:hover{
    background:#e7335f;
}

footer{
    margin-top:100px;
    color:#555;
}

</style>

</head>

<body>

<header>
Online Shopping Store
</header>

<div class="product">

<img src="https://images.unsplash.com/photo-1521572163474-6864f9cf17ab" alt="Tshirt">

<h2>Men Stylish T-Shirt</h2>

<p class="price">Price: ₹799</p>

<p>Premium cotton comfortable wear</p>

<a href="https://www.myntra.com" target="_blank">
<button>Buy on Myntra</button>
</a>

</div>

<footer>
SCM Lab Static Website Example
</footer>

</body>
</html>
